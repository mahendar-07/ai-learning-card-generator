# Server port
PORT=4000

# --- AI provider ---
# Get your free Gemini API key at https://aistudio.google.com/app/apikey
# If left blank, the server falls back to built-in mock cards so the app
# can still be demoed without any API key or cost.
GEMINI_API_KEY=

# Optional: override the default model (gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-pro

# Origin allowed to connect (your frontend dev server)
CLIENT_ORIGIN=http://localhost:5173
